import os
import sys
import h5py
import matplotlib.pyplot as plt
import numpy as np
from scipy import signal

from gprMax.exceptions import CmdInputError
from gprMax.utilities import fft_power

def mpl_plot(filename, use_fft=False, use_closeup=False, closeup_x_start=None, closeup_x_end=None):
    """
    Plots electric fields (Ex, Ey, Ez) for receiver 1.
    Generates a stacked plot and individual plots, with optional FFT and close-up views.
    """
    
    # Open output file and read attributes
    f = h5py.File(filename, 'r')
    nrx = f.attrs['nrx']
    dt = f.attrs['dt']
    iterations = f.attrs['Iterations']
    time = np.linspace(0, (iterations - 1) * dt, num=iterations) / 1e-9 # [ns]

    if nrx == 0:
        raise CmdInputError('No receivers found in {}'.format(filename))

    # 基本的に rx1 のみを使用
    path = '/rxs/rx1/'
    availableoutputs = list(f[path].keys())
    outputs = ['Ex', 'Ey', 'Ez']

    # 必要な電場成分がファイル内に存在するか確認
    for output in outputs:
        if output not in availableoutputs:
            raise CmdInputError(f'{output} output requested to plot, but it is not available in rx1.')

    # データ読み込み
    data = {}
    for output in outputs:
        data[output] = f[path + output][:]

    # クローズアップ・軸の共通範囲（自動設定）の計算
    x_start_idx = 0
    x_end_idx = len(time)
    
    if use_closeup:
        x_lim = [closeup_x_start, closeup_x_end]
        x_start_idx = max(0, np.searchsorted(time, closeup_x_start) - 1)
        x_end_idx = min(len(time), np.searchsorted(time, closeup_x_end) + 1)
    else:
        x_lim = [0, np.amax(time)]

    # 指定されたX軸範囲内でのY軸の最大・最小値を計算し共通化
    global_max = max([np.amax(data[out][x_start_idx:x_end_idx]) for out in outputs])
    global_min = min([np.amin(data[out][x_start_idx:x_end_idx]) for out in outputs])
    y_margin = (global_max - global_min) * 0.05
    if y_margin == 0:
        y_margin = 0.1
    y_lim = [global_min - y_margin, global_max + y_margin]

    # 出力ディレクトリとベースファイル名の設定
    base_dir = os.path.dirname(os.path.abspath(filename))
    base_name = os.path.splitext(os.path.basename(filename))[0]

    if use_closeup:
        out_dir = os.path.join(base_dir, f'closeup_{closeup_x_start}_{closeup_x_end}')
        os.makedirs(out_dir, exist_ok=True)
    else:
        out_dir = base_dir

    colors = {'Ex': 'r', 'Ey': 'g', 'Ez': 'b'}

    # 1. Ex, Ey, Ez成分を縦に並べたプロット (Stacked Plot)
    fig_stack, axs = plt.subplots(3, 1, figsize=(15, 12), sharex=True, facecolor='w', tight_layout=True)
    for i, comp in enumerate(outputs):
        axs[i].plot(time, data[comp], color=colors[comp], lw=2, label=comp)
        axs[i].set_ylabel(f'{comp} [V/m]', fontsize=20)
        axs[i].set_ylim(y_lim)
        axs[i].set_xlim(x_lim)
        axs[i].grid(which='both', axis='both', linestyle='--')
        axs[i].tick_params(labelsize=16)
        axs[i].legend(fontsize=16, loc='upper right')
    
    axs[-1].set_xlabel('Time [ns]', fontsize=20)
    stack_fname = os.path.join(out_dir, f"{base_name}_stacked.png")
    fig_stack.savefig(stack_fname, dpi=150, bbox_inches='tight')
    plt.show()

    # 2-4. 個別プロット (Ex, Ey, Ez)
    for comp in outputs:
        if use_fft:
            # 波形とFFTの横並びプロット
            fig, (ax1, ax2) = plt.subplots(nrows=1, ncols=2, figsize=(22, 8), facecolor='w', tight_layout=True)
            
            # Time Domain (左)
            ax1.plot(time, data[comp], color=colors[comp], lw=2, label=comp)
            ax1.set_xlabel('Time [ns]', fontsize=24)
            ax1.set_ylabel(f'{comp} [V/m]', fontsize=24)
            ax1.set_xlim(x_lim)
            ax1.set_ylim(y_lim)
            ax1.grid(which='both', axis='both', linestyle='--')
            ax1.tick_params(labelsize=20)
            ax1.legend(fontsize=20)

            # Frequency Domain (右)
            freqs, power = fft_power(data[comp], dt)
            try:
                freqmaxpower = np.where(np.isclose(power, 0))[0][0]
                pltrange = np.where(power[freqmaxpower:] < -60)[0][0] + freqmaxpower + 1
            except:
                freqmaxpower = np.argmax(power)
                pltrange = min(len(power), freqmaxpower * 4)
                if pltrange == 0: pltrange = len(power)

            pltrange_slice = np.s_[0:pltrange]
            
            ax2.plot(freqs[pltrange_slice]/1e6, power[pltrange_slice], 'k', lw=2)
            ax2.set_xlabel('Frequency [MHz]', fontsize=24)
            ax2.set_ylabel('Power [dB]', fontsize=24)
            ax2.set_ylim([-60, max(5, np.amax(power) + 5)])
            ax2.grid(which='both', axis='both', linestyle='--')
            ax2.tick_params(labelsize=20)

            fname = os.path.join(out_dir, f"{base_name}_{comp}_fft.png")
            fig.savefig(fname, dpi=150, bbox_inches='tight')
            plt.close(fig)

        else:
            # 時間波形のみの個別プロット
            fig, ax = plt.subplots(figsize=(12, 8), facecolor='w', tight_layout=True)
            ax.plot(time, data[comp], color=colors[comp], lw=2, label=comp)
            ax.set_xlabel('Time [ns]', fontsize=24)
            ax.set_ylabel(f'{comp} [V/m]', fontsize=24)
            ax.set_xlim(x_lim)
            ax.set_ylim(y_lim)
            ax.grid(which='both', axis='both', linestyle='--')
            ax.tick_params(labelsize=20)
            ax.legend(fontsize=20)

            fname = os.path.join(out_dir, f"{base_name}_{comp}.png")
            fig.savefig(fname, dpi=150, bbox_inches='tight')
            plt.close(fig)

    f.close()
    print(f"Plots successfully generated and saved to: {out_dir}")

if __name__ == "__main__":
    print("Plots electric fields (Ex, Ey, Ez) from receiver 1.")
    
    # Get output file path
    outputfile = input("Enter the path to the output file: ").strip()
    if not os.path.exists(outputfile):
        raise CmdInputError('Output file {} does not exist'.format(outputfile))
    
    # Get FFT option
    fft_input = input("Plot FFT alongside time-domain? (y/n) [default: n]: ").strip().lower()
    use_fft = fft_input == 'y'
    
    # Get closeup option
    closeup_input = input("Plot close up of time domain signal? (y/n) [default: n]: ").strip().lower()
    use_closeup = closeup_input == 'y'
    
    closeup_x_start = None
    closeup_x_end = None
    if use_closeup:
        closeup_x_start = float(input("Enter close up x-axis start [ns]: ").strip())
        closeup_x_end = float(input("Enter close up x-axis end [ns]: ").strip())
        print("Note: Y-axis limits will be automatically scaled based on the data within the specified X-axis range.")

    mpl_plot(outputfile, use_fft=use_fft, use_closeup=use_closeup, 
             closeup_x_start=closeup_x_start, closeup_x_end=closeup_x_end)